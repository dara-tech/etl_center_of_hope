{
  "name": "db-exporter-dashboard",
  "version": "1.0.0",
  "description": "Modern database exporter and backup dashboard",
  "main": "server.js",
  "bin": "scheduled-task/scheduled-etl.js",
  "scripts": {
    "start": "node server.js",
    "build:etl": "pkg . --targets node18-win-x64 --output etl-tool.exe"
  },
  "pkg": {
    "assets": [
      "sql/**/*"
    ]
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "msnodesqlv8": "^5.2.0",
    "mssql": "^10.0.2",
    "mysql2": "^3.9.7"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
